# ------------------------------------------------------------------
# Backend environment variables (copy to `.env` and fill in real values)
# NEVER commit the real .env file.
# ------------------------------------------------------------------

# Django core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Comma-separated hostnames Django will serve (no scheme).
# Local dev + your Render domain in production.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated frontend origins allowed to call the API (with scheme).
# Local Vite dev server + your Vercel domain in production.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Comma-separated origins trusted for CSRF (your deployed frontend/backend URLs).
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ------------------------------------------------------------------
# MySQL database
#   Local dev  -> your local MySQL / MariaDB
#   Production -> your managed MySQL host (e.g. Aiven)
# ------------------------------------------------------------------
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306

# Set to "require" when the DB host enforces TLS (e.g. Aiven). Otherwise leave blank.
DB_SSL_MODE=
